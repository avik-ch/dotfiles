theme = rose pine
background-opacity = 0.95
background-blur = 20
font-family = JetBrains Mono 
font-size = 16
confirm-close-surface = false
bold-is-bright = true
quit-after-last-window-closed = true
alpha-blending = linear
macos-icon = xray
# custom-shader = ~/.config/ghostty/ghostty_shaders/cursor_smear_fade.glsl
# custom-shader = ~/.config/ghostty/ghostty_shaders/cursor_smear_gradient.glsl
# custom-shader = ~/.config/ghostty/ghostty_shaders/cursor_blaze.glsl
custom-shader = ~/.config/ghostty/ghostty_shaders/cursor_smear.glsl

# move between splits with vim keys
keybind = super+ctrl+h=goto_split:left
keybind = super+ctrl+j=goto_split:down
keybind = super+ctrl+k=goto_split:up
keybind = super+ctrl+l=goto_split:right

# resize splits with vim keys
keybind = super+alt+h=resize_split:left,10
keybind = super+alt+j=resize_split:down,10
keybind = super+alt+k=resize_split:up,10
keybind = super+alt+l=resize_split:right,10

